# =============================================================================
# Polymath OS — Docker Environment Template
# =============================================================================
# Copy this file and fill in all required values before starting the stack:
#
#   cp .env.docker.example .env
#
# This file is committed to the repository with BLANK secret values.
# NEVER commit your filled-in .env to version control.
# =============================================================================


# =============================================================================
# 🔐 CORE SECRETS — Required for Polymath OS
# =============================================================================
# Generate fresh values for EVERY environment. NEVER reuse development secrets
# in production. The dev value in server/.env is considered compromised.
#
#   DB_PASSWORD    : openssl rand -base64 24
#   SESSION_SECRET : openssl rand -hex 32   (rotating this logs out ALL users)
#
# Prefer Docker secrets or a host secret manager over plaintext .env where
# possible for long-lived production deployments.

# PostgreSQL password for the Polymath OS database (user: productivity)
DB_PASSWORD=

# Express session signing secret — must be at least 32 characters
SESSION_SECRET=


# =============================================================================
# 🌐 DOMAIN & DEPLOYMENT
# =============================================================================
# Set to your actual domain before building the client image.
# VITE_API_URL is baked into the React bundle at build time — rebuilding is
# required when the domain changes.

# Browser origin the API allows via CORS (no trailing slash)
CLIENT_ORIGIN=https://mightguy.my.id

# API base URL baked into the client bundle at build time
VITE_API_URL=https://mightguy.my.id

# Cloudflare Zero Trust Tunnel token (generate in Cloudflare dashboard)
# This is the sole inbound path — the host has ZERO open inbound ports.
# Dashboard: https://one.dash.cloudflare.com → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=


# =============================================================================
# 🤖 ARTIFICIAL INTELLIGENCE — DeepSeek API + Embeddings
# =============================================================================
# DEEPSEEK_API_KEY is shared across chat AND embeddings — one key covers both.
# Leave it blank to disable all cloud AI. The local R1 model needs Ollama
# running with deepseek-r1:7b pulled at OLLAMA_BASE_URL.

# DeepSeek API key (get from https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# DeepSeek API base URL (change only if using a proxy or alternative endpoint)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Local Ollama base URL for the deepseek-r1:7b model (local-only mode)
OLLAMA_BASE_URL=http://localhost:11434

# --- Semantic Search & Auto-Tag Embeddings (optional) ----------------------
# Leave EMBEDDING_API_KEY blank to disable. These features degrade gracefully
# (empty semantic results) while keyword search continues to work normally.
# EMBEDDING_DIMENSIONS MUST match the vector(N) column in migration 014 (1536).

EMBEDDING_API_URL=https://api.deepseek.com/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536


# =============================================================================
# 📊 MONITORING & OBSERVABILITY
# =============================================================================

# Grafana admin password — MUST be changed from the default before deploying.
# The Grafana subdomain is publicly reachable via Cloudflare; a weak password
# is a direct security risk.
# Generate: openssl rand -hex 16
GRAFANA_PASSWORD=

# Uptime Kuma Telegram alert notifications (optional)
# Configure the bot in @BotFather, then get the chat ID from the Telegram API.
# These are consumed by Uptime Kuma's notification settings (configured in UI).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# =============================================================================
# 💾 OFFSITE BACKUP — Restic → Cloudflare R2
# =============================================================================
# The restic-backup container reads ALL variables in this file via env_file.
# Covers 9 data stores: Polymath DB dumps, Gitea, Grafana, Uptime Kuma,
# Vaultwarden, Miniflux DB, Wallabag, Nextcloud files, Nextcloud DB.
#
# Leave RESTIC_REPOSITORY blank to skip offsite backup (local-only operation).
#
# ⚠️  RESTIC_PASSWORD is the sole decryption key for all backup snapshots.
#     Store it securely OUTSIDE the server (password manager, printed copy).
#     Loss of this password = all encrypted backups permanently unrecoverable.
#
# R2 repository format: s3:https://<account>.r2.cloudflarestorage.com/<bucket>
# Generate API token in Cloudflare dashboard → R2 → Manage API Tokens

RESTIC_REPOSITORY=
RESTIC_PASSWORD=

# Cloudflare R2 (or AWS S3) credentials for Restic
# R2: create an API token with Object Read & Write on the target bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# =============================================================================
# 🗄️ DATABASE BACKUP — pg_dump sidecar (optional off-host sync)
# =============================================================================
# The db_backup container runs pg_dump on BACKUP_SCHEDULE and writes compressed
# .sql.gz files to the postgres_backups volume. Set BACKUP_S3_BUCKET to also
# push each dump off-host to S3 / Cloudflare R2.
# Leave BACKUP_S3_BUCKET empty to keep local-only dumps.
#
# Restore procedure:
#   docker run --rm -v postgres_backups:/backups -e PGPASSWORD=<DB_PASSWORD> \
#     postgres:16-alpine sh -c \
#     "gunzip -c /backups/<file>.sql.gz | \
#      psql postgresql://productivity:<DB_PASSWORD>@db:5432/productivity_db"

# Cron schedule for pg_dump (default: 02:00 daily)
BACKUP_SCHEDULE=0 2 * * *

# S3/R2 bucket name (leave blank to disable off-host sync)
BACKUP_S3_BUCKET=

# R2 endpoint: https://<account>.r2.cloudflarestorage.com
# AWS S3: leave blank (boto3 uses the default endpoint)
BACKUP_S3_ENDPOINT=

# S3/R2 credentials for pg_dump off-host sync (can differ from Restic creds)
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=

# R2: auto | AWS: region code e.g. ap-southeast-1
BACKUP_S3_REGION=auto


# =============================================================================
# 🔐 PASSWORD MANAGER — Vaultwarden (Bitwarden-compatible)
# =============================================================================
# Vaultwarden is self-hosted Bitwarden. SIGNUPS_ALLOWED=false (set in Compose)
# so only the admin can invite users.
#
# ADMIN_TOKEN grants access to the /admin panel.
# Generate: openssl rand -base64 48

VAULTWARDEN_DOMAIN=https://vault.mightguy.my.id
VAULTWARDEN_ADMIN_TOKEN=


# =============================================================================
# 📰 RSS READER — Miniflux
# =============================================================================
# Miniflux uses its own PostgreSQL container (miniflux-db).
# The admin account is created automatically on first run via CREATE_ADMIN=1
# (set in docker-compose.yml).

# PostgreSQL password for the Miniflux database (user: miniflux)
MINIFLUX_DB_PASSWORD=

# Miniflux admin credentials (created automatically on first start)
MINIFLUX_ADMIN_USERNAME=
MINIFLUX_ADMIN_PASSWORD=


# =============================================================================
# 📖 READ-LATER — Wallabag
# =============================================================================
# Wallabag stores articles for offline reading.
# The admin account is created via the web UI on first run (POPULATE_DATABASE=true
# is set in docker-compose.yml).
#
# SECRET: application signing secret — generate with: openssl rand -hex 32

WALLABAG_SECRET=

# Wallabag admin credentials (set through the first-run web UI at /install)
WALLABAG_ADMIN_PASSWORD=


# =============================================================================
# ☁️ FILE CLOUD — Nextcloud (Google Drive replacement)
# =============================================================================
# Nextcloud uses MariaDB (nextcloud-db) and Redis (nextcloud-redis) as defined
# in docker-compose.yml. Data is persisted to /mnt/data/nextcloud on the host.
#
# NEXTCLOUD_DB_ROOT_PASSWORD : MariaDB root password (used only at DB init)
# NEXTCLOUD_DB_PASSWORD      : MariaDB nextcloud user password (used at runtime)

NEXTCLOUD_ADMIN_USER=
NEXTCLOUD_ADMIN_PASSWORD=
NEXTCLOUD_DB_ROOT_PASSWORD=
NEXTCLOUD_DB_PASSWORD=


# =============================================================================
# 📝 ERROR REPORTING — Sentry (optional)
# =============================================================================
# Leave both blank to disable error reporting entirely. When set:
#   SENTRY_DSN      → server-side (Express) — add to api container's environment
#                     in docker-compose.yml alongside the other api env vars
#   VITE_SENTRY_DSN → client-side (React)  — baked into the bundle at build time
#
# DSN format: https://<key>@<org>.ingest.sentry.io/<project>

SENTRY_DSN=
VITE_SENTRY_DSN=
