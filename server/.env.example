# server/.env.example — copy to server/.env and fill in. NEVER commit a populated .env (§6.0, §10 NEVER #8).

# Postgres connection string for the pg pool (required).
DATABASE_URL=

# Allowed CORS origin — the client dev server (required).
CLIENT_ORIGIN=http://localhost:5173

# Signs the auth session cookie. Use a random 32+ char string (required).
SESSION_SECRET=

# Express listen port (optional, defaults to 3000).
PORT=3000

# Node environment: development | production (optional).
NODE_ENV=development
