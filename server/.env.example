# server/.env.example — copy to server/.env and fill in. NEVER commit a populated .env (§6.0, §10 NEVER #8).
#
# ⚠️ Phase 7 — SECRETS: generate fresh values for EVERY environment.
#   SESSION_SECRET : openssl rand -hex 32   (rotating it logs out all users)
#   DATABASE_URL password : openssl rand -base64 24
# NEVER reuse a development secret in production. The dev value in server/.env is
# considered compromised and must not be promoted. In production, prefer Docker
# secrets / host secret managers over a plaintext .env where possible.

# Postgres connection string for the pg pool (required).
DATABASE_URL=

# Allowed CORS origin — the client dev server (required).
CLIENT_ORIGIN=http://localhost:5173

# Signs the auth session cookie. Use a random 32+ char string (required).
SESSION_SECRET=

# Express listen port (optional, defaults to 3000).
PORT=3000

# Node environment: development | production (optional).
NODE_ENV=development

# Sentry DSN for server-side error reporting (optional — omit to disable Sentry).
# Obtain from https://sentry.io → Project Settings → Client Keys.
SENTRY_DSN=
