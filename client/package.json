{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:property": "vitest run --reporter=verbose src/test/formatIdr.property.test.js",
    "test:fuzz": "vitest run --reporter=verbose src/test/forms.fuzz.test.js",
    "test:input": "npm run test:property && npm run test:fuzz",
    "test:visual": "cross-env RUN_VISUAL=1 playwright test visual.spec.js",
    "test:smoke": "cross-env RUN_SMOKE=1 playwright test smoke-full.spec.js"
  },
  "dependencies": {
    "@sentry/react": "^10.57.0",
    "@uiw/react-md-editor": "4.1.1",
    "axios": "^1.7.9",
    "lucide-react": "^0.469.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.1.1",
    "rehype-sanitize": "^6.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
